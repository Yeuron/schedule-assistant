DB_HOST=your-oracle-host
DB_PORT=1521
DB_SERVICE=your-service-name
DB_USER=your-username
DB_PASSWORD=your-password
PORT=3000
LOG_LEVEL=info
NODE_ENV=production

# Oracle Instant Client 路径（Thick 模式）
# Windows 示例：C:\oracle\instantclient_21_13
# Linux 示例：/opt/oracle/instantclient_21_13
# 若已加入系统 PATH 可留空
ORACLE_CLIENT_LIB_DIR=
