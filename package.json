{
  "name": "schedule-assistant",
  "version": "1.0.0",
  "description": "Vue3 Gantt Chart Production Scheduling Assistant",
  "main": "server/index.js",
  "type": "commonjs",
  "scripts": {
    "dev": "concurrently \"cd client && npm run dev\" \"cd server && npm run dev\"",
    "build": "node build.js",
    "client:build": "cd client && npm run build",
    "server:start": "cd server && node index.js"
  },
  "keywords": [
    "vue3",
    "gantt",
    "production-scheduling",
    "express",
    "oracle"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "archiver": "^6.0.0",
    "concurrently": "^8.2.2"
  },
  "engines": {
    "node": ">=14.0.0",
    "npm": ">=6.0.0"
  }
}
