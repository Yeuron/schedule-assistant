# Schedule Assistant - 环境变量配置示例
# 复制此文件为 .env，然后填入实际的配置值

# ========== Oracle 数据库配置 ==========
# 数据库用户名
DB_USER=your_database_user

# 数据库密码
DB_PASSWORD=your_database_password

# 数据库主机地址
DB_HOST=localhost

# 数据库端口
DB_PORT=1521

# 数据库服务名/SID
DB_SERVICE=ORCL

# ========== 应用配置 ==========
# 应用监听端口
PORT=3000

# 日志级别 (error, warn, info, debug)
LOG_LEVEL=info

# 运行环境 (development, production)
NODE_ENV=production

# ========== Oracle Instant Client 配置（可选）==========
# 如已配置系统 PATH 或 LD_LIBRARY_PATH，可留空
# Windows 示例: C:\oracle\instantclient_21_12
# Linux 示例: /usr/lib/oracle/21/client64/lib
ORACLE_CLIENT_LIB_DIR=

# ========== 其他配置（可选）==========
# API 请求超时时间（毫秒）
# REQUEST_TIMEOUT=30000

# CORS 允许的源
# CORS_ORIGIN=http://localhost:3000

# 开发调试模式
# DEBUG=false
